{
  "name": "atlas",
  "displayName": "Atlas",
  "description": "A visual architecture workspace where the architecture model is the source of truth.",
  "version": "0.1.0",
  "publisher": "atlas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/afetiu/project-atlas.git"
  },
  "bugs": {
    "url": "https://github.com/afetiu/project-atlas/issues"
  },
  "homepage": "https://github.com/afetiu/project-atlas#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "architecture",
    "diagram",
    "canvas",
    "design",
    "yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atlas.openArchitecture",
        "title": "Open Architecture",
        "category": "Atlas"
      },
      {
        "command": "atlas.detectArchitecture",
        "title": "Detect Architecture from Code",
        "category": "Atlas"
      },
      {
        "command": "atlas.setApiKey",
        "title": "Set Anthropic API Key",
        "category": "Atlas"
      },
      {
        "command": "atlas.clearApiKey",
        "title": "Clear Anthropic API Key",
        "category": "Atlas"
      },
      {
        "command": "atlas.registerMcpServer",
        "title": "Register MCP Server for Claude Code",
        "category": "Atlas"
      },
      {
        "command": "atlas.export",
        "title": "Export Architecture (Mermaid / Markdown)",
        "category": "Atlas"
      }
    ],
    "configuration": {
      "title": "Atlas",
      "properties": {
        "atlas.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Claude model id Atlas should use (e.g. `claude-opus-4-8`). Leave empty to use the Claude Code default."
        },
        "atlas.claudeExecutablePath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Absolute path to the `claude` executable. Leave empty to use the one on your PATH."
        },
        "atlas.autoSync": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Automatically re-detect the architecture when source files change. Each sync is a full AI run, so this is **off** by default. Pending manual canvas edits are never overwritten."
        },
        "atlas.sourceRoot": {
          "type": "string",
          "default": "src",
          "markdownDescription": "Directory Atlas reads when mapping the architecture from code (the `Map from code` action). Set this to your code's root, e.g. `src`, `lib`, or `packages`."
        },
        "atlas.verifyCommand": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Command run after code generation to verify the result (e.g. `npm run typecheck`). The architecture baseline only advances when this succeeds. Leave empty to verify by mapped-path existence only. For safety this runs only in a trusted workspace, and cannot be set by a repository's workspace settings."
        },
        "atlas.mcpServers": {
          "type": "object",
          "default": {},
          "scope": "machine-overridable",
          "markdownDescription": "MCP servers Atlas can connect to, so a component bound to one becomes operable from the map. Each key is a server name (matched by a node's binding); the value is `{ \"command\": \"…\", \"args\": [\"…\"], \"env\": { … } }`. Example: `{ \"postgres\": { \"command\": \"npx\", \"args\": [\"-y\", \"@modelcontextprotocol/server-postgres\", \"postgres://…\"] } }`.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "cwd": {
                "type": "string"
              }
            },
            "required": [
              "command"
            ]
          }
        }
      }
    }
  },
  "activationEvents": [],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "node scripts/run-tests.mjs",
    "check": "node dist/atlas-check.mjs",
    "diff": "node dist/atlas-diff.mjs",
    "lint": "eslint src --ext ts,tsx",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.4",
    "yaml": "^2.3.4"
  }
}
